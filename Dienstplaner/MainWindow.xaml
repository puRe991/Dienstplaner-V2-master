<Window x:Class="Dienstplaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dienstplaner"
        Height="900"
        Width="1440"
        Background="#F3F4F6">

    <Grid>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#1B3A5C">

            <Grid>

                <TextBlock Text="Dienstplaner"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="20,0"/>

            </Grid>

        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1"
              Margin="10">

            <!-- COLUMNS -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================================== -->
            <!-- LEFT PANEL -->
            <!-- ===================================================== -->

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <!-- MITARBEITER -->
                    <Border Background="White"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,0,0,10">

                        <StackPanel>

                            <TextBlock Text="Mitarbeiter hinzufügen"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Name"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>

                            <TextBox Height="32"
                                     Text="{Binding NeuerMitarbeiterName}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Abteilung"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>

                            <TextBox Height="32"
                                     Text="{Binding NeueMitarbeiterAbteilung}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Qualifikation"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>

                            <TextBox Height="32"
                                     Text="{Binding NeuerMitarbeiterQualifikation}"
                                     Margin="0,0,0,8"/>

                            <Button Content="Mitarbeiter hinzufügen"
                                    Height="36"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding MitarbeiterHinzufuegenCommand}"/>

                        </StackPanel>

                    </Border>

                    <!-- SCHICHT -->
                    <Border Background="White"
                            CornerRadius="6"
                            Padding="14">

                        <StackPanel>

                            <TextBlock Text="Schicht hinzufügen"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Schichtname"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>

                            <TextBox Height="32"
                                     Text="{Binding NeueSchichtName}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Abteilung"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>

                            <TextBox Height="32"
                                     Text="{Binding NeueSchichtAbteilung}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Wochentag"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>

                            <TextBox Height="32"
                                     Text="{Binding NeueSchichtWochentag}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Benötigte Mitarbeiter"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>

                            <TextBox Height="32"
                                     Text="{Binding NeueSchichtKapazitaet}"
                                     Margin="0,0,0,12"/>

                            <Button Content="Schicht erstellen"
                                    Height="36"
                                    Background="#059669"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding SchichtHinzufuegenCommand}"/>

                        </StackPanel>

                    </Border>

                </StackPanel>

            </ScrollViewer>

            <!-- ===================================================== -->
            <!-- CENTER PANEL -->
            <!-- ===================================================== -->

            <StackPanel Grid.Column="1"
                        Margin="10,0">

                <!-- ZUWEISUNG -->
                <Border Background="White"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,10">

                    <StackPanel>

                        <TextBlock Text="Zuweisung"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Mitarbeiter"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>

                        <ComboBox Height="32"
                                  ItemsSource="{Binding MitarbeiterListe}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding AusgewaehlterMitarbeiter}"
                                  Margin="0,0,0,8"/>

                        <TextBlock Text="Schicht"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>

                        <ComboBox Height="32"
                                  ItemsSource="{Binding SchichtListe}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding AusgewaehlteSchicht}"
                                  Margin="0,0,0,12"/>

                        <Button Content="Mitarbeiter zuweisen"
                                Height="36"
                                Background="#EA580C"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding ZuweisenCommand}"/>

                    </StackPanel>

                </Border>

                <!-- SCHICHTEN -->
                <Border Background="White"
                        CornerRadius="6"
                        Padding="14">

                    <StackPanel>

                        <TextBlock Text="Geplante Schichten"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Margin="0,0,0,12"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Height="600">

                            <ItemsControl ItemsSource="{Binding SchichtListe}">

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <Border BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,0,1"
                                                Padding="8">

                                            <StackPanel>

                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="14"/>

                                                <TextBlock Text="{Binding Abteilung,
                                                    StringFormat=Abteilung: {0}}"
                                                           FontSize="11"
                                                           Opacity="0.7"/>

                                                <TextBlock Text="{Binding Wochentag,
                                                    StringFormat=Tag: {0}}"
                                                           FontSize="11"/>

                                                <TextBlock Text="{Binding BenoetigteMitarbeiter,
                                                    StringFormat=Benötigt: {0} Mitarbeiter}"
                                                           FontSize="11"/>

                                                <TextBlock Text="{Binding MitarbeiterNamen.Count,
                                                    StringFormat=Zugewiesen: {0}}"
                                                           FontSize="11"
                                                           Margin="0,0,0,5"/>

                                                <TextBlock Text="Eingeplante Mitarbeiter:"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,4,0,2"/>

                                                <ItemsControl ItemsSource="{Binding MitarbeiterNamen}">

                                                    <ItemsControl.ItemTemplate>

                                                        <DataTemplate>

                                                            <Border Background="#EEF2FF"
                                                                    CornerRadius="4"
                                                                    Padding="4"
                                                                    Margin="0,2,0,2">

                                                                <TextBlock Text="{Binding}"
                                                                           FontSize="11"/>

                                                            </Border>

                                                        </DataTemplate>

                                                    </ItemsControl.ItemTemplate>

                                                </ItemsControl>

                                            </StackPanel>

                                        </Border>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

            </StackPanel>

            <!-- ===================================================== -->
            <!-- RIGHT PANEL -->
            <!-- ===================================================== -->

            <StackPanel Grid.Column="2">

                <!-- MITARBEITER -->
                <Border Background="White"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,10">

                    <StackPanel>

                        <TextBlock Text="Mitarbeiter Übersicht"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Margin="0,0,0,12"/>

                        <ScrollViewer Height="500">

                            <ItemsControl ItemsSource="{Binding MitarbeiterListe}">

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <Border BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,0,1"
                                                Padding="8">

                                            <StackPanel>

                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"/>

                                                <TextBlock Text="{Binding Abteilung,
                                                    StringFormat=Abteilung: {0}}"
                                                           FontSize="11"
                                                           Opacity="0.7"/>

                                                <TextBlock Text="{Binding Qualifikation,
                                                    StringFormat=Qualifikation: {0}}"
                                                           FontSize="11"/>

                                                <TextBlock Text="{Binding Schichten.Count,
                                                    StringFormat=Schichten: {0}}"
                                                           FontSize="11"/>

                                            </StackPanel>

                                        </Border>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

                <!-- STATUS -->
                <Border Background="White"
                        CornerRadius="6"
                        Padding="14">

                    <StackPanel>

                        <TextBlock Text="Systemstatus"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding StatusNachricht}"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

            </StackPanel>

        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="#1B3A5C">

            <TextBlock Text="{Binding StatusNachricht}"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10,0"/>

        </Border>

    </Grid>

</Window>