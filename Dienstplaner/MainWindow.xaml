<Window x:Class="Dienstplaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dienstplanung Pro"
        Height="900"
        Width="1440"
        MinHeight="820"
        MinWidth="1280"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Window.Resources>
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="16" ShadowDepth="2" Direction="270" Color="#110B1F3A" Opacity="0.42"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5EAF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
        </Style>

        <Style x:Key="NavItem" TargetType="Border">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="12,4"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="ActiveNavItem" TargetType="Border" BasedOn="{StaticResource NavItem}">
            <Setter Property="Background" Value="#EAF3FF"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#0B67E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0B67E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0B67E8"/>
            <Setter Property="BorderBrush" Value="#D8E3F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderBrush" Value="#DDE6F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="SchichtCardTemplate">
            <Border Background="#FBFDFF" BorderBrush="#E5EAF2" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <Border Grid.Column="1" Background="#DBEAFE" CornerRadius="10" Padding="8,2">
                            <TextBlock Text="{Binding MitarbeiterNamen.Count, StringFormat={}{0} zugewiesen}" Foreground="#0B4FD8" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding Abteilung, StringFormat=Abteilung: {0}}" Style="{StaticResource MutedText}" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding Rolle, StringFormat=Rolle: {0}}" Style="{StaticResource MutedText}"/>
                    <TextBlock Text="{Binding Wochentag, StringFormat=Tag: {0}}" Style="{StaticResource MutedText}"/>
                    <TextBlock Text="{Binding Start, StringFormat=Start: {0:dd.MM.yyyy HH:mm}}" Foreground="#0F172A" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding Ende, StringFormat=Ende: {0:dd.MM.yyyy HH:mm}}" Foreground="#0F172A" FontSize="12"/>
                    <TextBlock Text="{Binding NettoDauerInStunden, StringFormat=Netto: {0} h}" Style="{StaticResource MutedText}"/>
                    <ItemsControl ItemsSource="{Binding MitarbeiterNamen}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#EAF3FF" CornerRadius="5" Padding="7,3" Margin="0,2,4,2" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding}" Foreground="#0B67E8" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MitarbeiterTemplate">
            <Border BorderBrush="#EEF2F7" BorderThickness="0,0,0,1" Padding="0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="26" Height="26" CornerRadius="13" Background="#DBEAFE">
                        <TextBlock Text="●" Foreground="#0B67E8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="{Binding Qualifikation, StringFormat={}{0}}" Style="{StaticResource MutedText}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding Iststunden, StringFormat={}{0} h}" Foreground="#0B67E8" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" BorderBrush="#E5EAF2" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="480"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="7" Background="#0B67E8" Margin="0,0,12,0">
                        <TextBlock Text="▣" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Dienstplanung Pro" FontSize="20" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1" Height="38" CornerRadius="8" BorderBrush="#DDE6F1" BorderThickness="1" Background="#FBFDFF" VerticalAlignment="Center">
                    <Grid Margin="12,0">
                        <TextBlock Text="Suche, Filter und Navigation werden über die eingebundenen Listen gesteuert" Foreground="#8B97AA" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Width="38" Height="38" CornerRadius="19" Background="#D9EAFE" Margin="0,0,10,0">
                        <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Width="160">
                        <TextBlock Text="{Binding AktuellerBenutzer.Benutzername}" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="{Binding AktuellerBenutzer.Rolle}" Foreground="#64748B" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="White" BorderBrush="#E5EAF2" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>
                <StackPanel Margin="0,24,0,0">
                    <Border Style="{StaticResource NavItem}"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="⌂" Width="30" Foreground="#64748B" FontSize="18"/><TextBlock Text="Dashboard" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource ActiveNavItem}"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="▣" Width="30" Foreground="#0B67E8" FontSize="18"/><TextBlock Text="Dienstplan" Foreground="#0B67E8" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource NavItem}"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="♙" Width="30" Foreground="#64748B" FontSize="18"/><TextBlock Text="Mitarbeiter" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource NavItem}"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="◷" Width="30" Foreground="#64748B" FontSize="18"/><TextBlock Text="Schichten" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource NavItem}"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="▥" Width="30" Foreground="#64748B" FontSize="18"/><TextBlock Text="Berichte" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource NavItem}"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="⚙" Width="30" Foreground="#64748B" FontSize="18"/><TextBlock Text="Einstellungen" FontWeight="SemiBold"/></StackPanel></Border>
                </StackPanel>
                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="20" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Systemstatus" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding StatusNachricht}" TextWrapping="Wrap" Foreground="#334155" FontSize="12"/>
                    </StackPanel>
                </Border>
                <TextBlock Grid.Row="3" Text="© 2024 Dienstplanung Pro" Foreground="#64748B" Margin="24,0" VerticalAlignment="Center" FontSize="11"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,22,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Dienstplan" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Produktive Planung mit persistierten Mitarbeitern, Schichten, Regeln und Exporten" Foreground="#64748B" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Reports aktualisieren" Style="{StaticResource SecondaryButton}" Command="{Binding ReportsAktualisierenCommand}" Margin="0,0,8,0"/>
                            <Button Content="Dienstplan veröffentlichen" Style="{StaticResource PrimaryButton}" Command="{Binding DienstplanVeroeffentlichenCommand}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Mitarbeiter" Style="{StaticResource MutedText}" FontWeight="SemiBold"/><TextBlock Text="{Binding MitarbeiterListe.Count}" FontSize="26" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/><TextBlock Text="Aktive Datensätze" Foreground="#16A34A" FontSize="12"/></StackPanel></Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Schichten" Style="{StaticResource MutedText}" FontWeight="SemiBold"/><TextBlock Text="{Binding SchichtListe.Count}" FontSize="26" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/><TextBlock Text="Persistierte Planung" Foreground="#0B67E8" FontSize="12"/></StackPanel></Border>
                        <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Besetzung" Style="{StaticResource MutedText}" FontWeight="SemiBold"/><TextBlock Text="{Binding BesetzungIst, StringFormat={}{0} Ist}" FontSize="26" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/><TextBlock Text="{Binding BesetzungSoll, StringFormat=Soll: {0}}" Foreground="#64748B" FontSize="12"/></StackPanel></Border>
                        <Border Grid.Column="3" Style="{StaticResource Card}"><StackPanel><TextBlock Text="Konflikte" Style="{StaticResource MutedText}" FontWeight="SemiBold"/><TextBlock Text="{Binding KonfliktAnzahl}" FontSize="26" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/><TextBlock Text="Regelprüfung aktiv" Foreground="#DC2626" FontSize="12"/></StackPanel></Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*"/>
                            <ColumnDefinition Width="0.95*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,14,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Geplante Schichten" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="{Binding SchichtListe.Count, StringFormat={}{0} Einträge}" HorizontalAlignment="Right" Foreground="#64748B"/>
                                </Grid>
                                <ScrollViewer Height="520" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SchichtListe}" ItemTemplate="{StaticResource SchichtCardTemplate}"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Zuweisung &amp; Aktionen" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10"/>
                                    <TextBlock Text="Mitarbeiter" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Height="30" ItemsSource="{Binding MitarbeiterView}" DisplayMemberPath="Name" SelectedItem="{Binding AusgewaehlterMitarbeiter, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Schicht" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Height="30" ItemsSource="{Binding SchichtView}" DisplayMemberPath="Name" SelectedItem="{Binding AusgewaehlteSchicht, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="Zuweisen" Style="{StaticResource PrimaryButton}" Command="{Binding ZuweisenCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Schicht löschen" Style="{StaticResource DangerButton}" Command="{Binding SchichtLoeschenCommand}"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding ZuweisungsFehler}" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap"/></DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding ZuweisungsWarnungen}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" Foreground="#B45309" FontSize="12" TextWrapping="Wrap"/></DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Mitarbeiter anlegen" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeuerMitarbeiterName, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Abteilung" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueMitarbeiterAbteilung, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Qualifikation" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeuerMitarbeiterQualifikation, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,6,0"><TextBlock Text="Sollstunden" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueMitarbeiterSollstunden, UpdateSourceTrigger=PropertyChanged}"/></StackPanel><StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="Stundenlohn" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeuerMitarbeiterStundenlohn, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid>
                                    <Button Content="Mitarbeiter speichern" Style="{StaticResource PrimaryButton}" Command="{Binding MitarbeiterHinzufuegenCommand}" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Schicht anlegen" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueSchichtName, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Abteilung" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueSchichtAbteilung, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Wochentag" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueSchichtWochentag, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Datum" Style="{StaticResource FieldLabel}"/><DatePicker SelectedDate="{Binding NeueSchichtDatum, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,6,0"><TextBlock Text="Start" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueSchichtStartzeit, UpdateSourceTrigger=PropertyChanged}"/></StackPanel><StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="Ende" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueSchichtEndzeit, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,6,0"><TextBlock Text="Kapazität" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueSchichtKapazitaet, UpdateSourceTrigger=PropertyChanged}"/></StackPanel><StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="Pause (h)" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding NeueSchichtPausenstunden, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid>
                                    <Button Content="Schicht speichern" Style="{StaticResource PrimaryButton}" Command="{Binding SchichtHinzufuegenCommand}" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10"><TextBlock Text="Mitarbeiter" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/><TextBlock Text="{Binding MitarbeiterListe.Count, StringFormat={}{0}}" HorizontalAlignment="Right" Foreground="#64748B"/></Grid>
                            <ScrollViewer Height="210" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MitarbeiterListe}" ItemTemplate="{StaticResource MitarbeiterTemplate}"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Geschützte Exporte" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,8"/>
                            <TextBlock Text="Mandant, Filiale, Rolle und Exportformat werden vor dem Export geprüft." TextWrapping="Wrap" Style="{StaticResource MutedText}" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="CSV" Style="{StaticResource SecondaryButton}" Width="70" Command="{Binding CsvExportCommand}" Margin="0,0,8,0"/>
                                <Button Content="Excel" Style="{StaticResource SecondaryButton}" Width="70" Command="{Binding ExcelExportCommand}" Margin="0,0,8,0"/>
                                <Button Content="PDF" Style="{StaticResource SecondaryButton}" Width="70" Command="{Binding PdfExportCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10"><TextBlock Text="Reports" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/><Button Content="Aktualisieren" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Command="{Binding ReportsAktualisierenCommand}"/></Grid>
                            <ItemsControl ItemsSource="{Binding ReportListe}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#EEF2F7" BorderThickness="0,1,0,0" Padding="0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                                <TextBlock Text="{Binding Wert}" Foreground="#0B67E8" FontSize="17" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Hinweis}" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10"><TextBlock Text="Lohn &amp; Zeiterfassung" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/><Button Content="Aktualisieren" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Command="{Binding IntegrationenAktualisierenCommand}"/></Grid>
                            <TextBlock Text="Lohnabrechnung" FontWeight="SemiBold" Foreground="#0F172A"/>
                            <ScrollViewer Height="70"><ItemsControl ItemsSource="{Binding LohnabrechnungListe}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock FontSize="11" Foreground="#334155" Text="{Binding MitarbeiterName, StringFormat={}{0}: Soll/Ist/Kosten bereitgestellt}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
                            <TextBlock Text="Zeiterfassung" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,8,0,0"/>
                            <ScrollViewer Height="70"><ItemsControl ItemsSource="{Binding ZeiterfassungListe}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock FontSize="11" Foreground="#334155" Text="{Binding SchichtName, StringFormat={}{0}: Zeiten und Kostenstelle}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Forecast-Import" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                            <TextBlock Text="CSV-Pfad" Style="{StaticResource FieldLabel}"/><TextBox Style="{StaticResource Input}" Text="{Binding ForecastImportPfad, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Forecast importieren" Style="{StaticResource PrimaryButton}" Command="{Binding ForecastImportCommand}" Margin="0,10,0,8"/>
                            <ScrollViewer Height="80"><ItemsControl ItemsSource="{Binding ForecastListe}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock FontSize="11" Foreground="#334155" Text="{Binding FilialeName, StringFormat={}{0}: Forecast importiert}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="DSGVO" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                            <TextBlock Text="Ausgewählten Mitarbeiter aus der Zuweisungsauswahl verwenden." TextWrapping="Wrap" Style="{StaticResource MutedText}" Margin="0,4,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Auskunft" Style="{StaticResource SecondaryButton}" Command="{Binding DsgvoAuskunftCommand}" Margin="0,0,8,0"/>
                                <Button Content="Löschen" Style="{StaticResource DangerButton}" Command="{Binding DsgvoLoeschenCommand}"/>
                            </StackPanel>
                            <TextBox Text="{Binding DsgvoExportText}" Height="76" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Audit &amp; Compliance" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ComplianceRichtlinie.Exportkonzept}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <ScrollViewer Height="120">
                                <ItemsControl ItemsSource="{Binding AuditLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Aktion}" FontWeight="SemiBold" FontSize="11"/>
                                                <TextBlock Text="{Binding Benutzer}" Style="{StaticResource MutedText}"/>
                                                <TextBlock Text="{Binding ZeitpunktUtc}" Style="{StaticResource MutedText}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
