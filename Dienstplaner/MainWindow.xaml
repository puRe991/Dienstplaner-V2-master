<Window x:Class="Dienstplaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dienstplanung Pro"
        Height="900"
        Width="1440"
        MinHeight="820"
        MinWidth="1280"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Window.Resources>
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="2" Direction="270" Color="#110B1F3A" Opacity="0.45"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5EAF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
        </Style>

        <Style x:Key="NavItem" TargetType="Border">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="12,4"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="ActiveNavItem" TargetType="Border" BasedOn="{StaticResource NavItem}">
            <Setter Property="Background" Value="#EAF3FF"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#0B67E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0B67E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#DEE6F2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="TinyActionButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0B67E8"/>
            <Setter Property="BorderBrush" Value="#D8E3F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CellShift" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" BorderBrush="#E5EAF2" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="480"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="7" Background="#0B67E8" Margin="0,0,12,0">
                        <TextBlock Text="▣" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Dienstplanung Pro" FontSize="20" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Height="38" CornerRadius="8" BorderBrush="#DDE6F1" BorderThickness="1" Background="#FBFDFF" VerticalAlignment="Center">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="46"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⌕" FontSize="18" Foreground="#64748B" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Suche nach Mitarbeitern, Schichten..." Foreground="#8B97AA" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Height="24" Background="#F1F5F9" CornerRadius="5" VerticalAlignment="Center">
                            <TextBlock Text="⌘ K" Foreground="#64748B" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                    <Grid Width="34" Height="34" Margin="0,0,18,0">
                        <TextBlock Text="♧" FontSize="22" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border Background="#EF4444" CornerRadius="8" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="3" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Width="38" Height="38" CornerRadius="19" Background="#D9EAFE" Margin="0,0,10,0">
                        <TextBlock Text="👨" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Width="150">
                        <TextBlock Text="Max Mustermann" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Administrator" Foreground="#64748B" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Text="⌄" FontSize="18" Foreground="#0F172A" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Background="White" BorderBrush="#E5EAF2" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,24,0,0">
                    <Border Style="{StaticResource NavItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⌂" FontSize="19" Foreground="#64748B" Width="30"/>
                            <TextBlock Text="Dashboard" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ActiveNavItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="▣" FontSize="18" Foreground="#0B67E8" Width="30"/>
                            <TextBlock Text="Dienstplan" FontWeight="SemiBold" Foreground="#0B67E8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NavItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="♙" FontSize="18" Foreground="#64748B" Width="30"/>
                            <TextBlock Text="Mitarbeiter" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NavItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="♧" FontSize="18" Foreground="#64748B" Width="30"/>
                            <TextBlock Text="Abwesenheiten" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NavItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="◷" FontSize="18" Foreground="#64748B" Width="30"/>
                            <TextBlock Text="Schichten" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NavItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="▥" FontSize="18" Foreground="#64748B" Width="30"/>
                            <TextBlock Text="Berichte" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NavItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="18" Foreground="#64748B" Width="30"/>
                            <TextBlock Text="Einstellungen" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Row="2" Margin="20" Padding="16" CornerRadius="10" Background="White" BorderBrush="#E5EAF2" BorderThickness="1" Effect="{StaticResource SoftShadow}">
                    <StackPanel>
                        <TextBlock Text="◔" FontSize="18" Foreground="#0B67E8"/>
                        <TextBlock Text="Nächste Schicht" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,8,0,14"/>
                        <TextBlock Text="Heute, 20:00 – 06:00" Foreground="#0F172A" FontSize="13"/>
                        <Border Background="#DBEAFE" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,10,0,20">
                            <TextBlock Text="Nachtschicht" Foreground="#0B4FD8" FontWeight="SemiBold" FontSize="11"/>
                        </Border>
                        <TextBlock Text="Standort" Style="{StaticResource MutedText}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌖" Foreground="#64748B" Margin="0,0,8,0"/>
                            <TextBlock Text="Zentrale Wache" Foreground="#0F172A" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="3" Text="© 2024 Dienstplanung Pro" Foreground="#64748B" Margin="24,0" VerticalAlignment="Center" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,22,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Dienstplan" FontSize="28" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,26,0"/>
                            <Button Content="‹" Style="{StaticResource SecondaryButton}" Width="40"/>
                            <Button Content="📅   19. – 25. Mai 2024  ⌄" Style="{StaticResource SecondaryButton}" Width="190" Margin="-1,0,0,0"/>
                            <Button Content="›" Style="{StaticResource SecondaryButton}" Width="40" Margin="-1,0,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="◎  Ansicht  ⌄" Style="{StaticResource SecondaryButton}" Width="118" Margin="0,0,12,0"/>
                            <Button Content="⊕  Schicht hinzufügen" Style="{StaticResource PrimaryButton}" Width="160" Command="{Binding SchichtHinzufuegenCommand}"/>
                        </StackPanel>
                    </Grid>

                    <!-- KPI cards -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="42" Height="42" CornerRadius="21" Background="#0B67E8"><TextBlock Text="♙" Foreground="White" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Mitarbeiter" Style="{StaticResource MutedText}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,4"><TextBlock Text="{Binding MitarbeiterListe.Count}" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/><TextBlock Text=" Aktiv" Foreground="#16A34A" FontSize="12" VerticalAlignment="Center" Margin="12,8,0,0"/></StackPanel>
                                    <TextBlock Text="2 in Abwesenheit" Foreground="#0B67E8" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="42" Height="42" CornerRadius="21" Background="#FDBA3B"><TextBlock Text="▣" Foreground="#0F172A" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Offene Schichten" Style="{StaticResource MutedText}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding KonfliktAnzahl}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,6,0,4"/>
                                    <TextBlock Text="Davon 2 kritisch" Foreground="#DC2626" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="42" Height="42" CornerRadius="21" Background="#BBF7D0"><TextBlock Text="♧" Foreground="#0F5132" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Abwesenheiten" Style="{StaticResource MutedText}" FontWeight="SemiBold"/>
                                    <TextBlock Text="5" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,6,0,4"/>
                                    <TextBlock Text="Genehmigt" Foreground="#15803D" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="42" Height="42" CornerRadius="21" Background="#E9D5FF"><TextBlock Text="◷" Foreground="#6D28D9" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Stunden diese Woche" Style="{StaticResource MutedText}" FontWeight="SemiBold"/>
                                    <TextBlock Text="892 h" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,6,0,4"/>
                                    <TextBlock Text="Ø 37,2 h pro Mitarbeiter" Foreground="#64748B" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Schedule board -->
                    <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="54"/>
                                <RowDefinition Height="48"/>
                                <RowDefinition Height="48"/>
                                <RowDefinition Height="48"/>
                                <RowDefinition Height="48"/>
                                <RowDefinition Height="48"/>
                                <RowDefinition Height="48"/>
                                <RowDefinition Height="48"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.ColumnSpan="8" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Mitarbeiter" FontWeight="SemiBold" Foreground="#0F172A" Margin="20,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="Montag" Style="{StaticResource HeaderText}"/><TextBlock Text="19. Mai" Style="{StaticResource MutedText}" HorizontalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"><TextBlock Text="Dienstag" Style="{StaticResource HeaderText}"/><TextBlock Text="20. Mai" Style="{StaticResource MutedText}" HorizontalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"><TextBlock Text="Mittwoch" Style="{StaticResource HeaderText}"/><TextBlock Text="21. Mai" Style="{StaticResource MutedText}" HorizontalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="4" VerticalAlignment="Center"><TextBlock Text="Donnerstag" Style="{StaticResource HeaderText}"/><TextBlock Text="22. Mai" Style="{StaticResource MutedText}" HorizontalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="5" VerticalAlignment="Center"><TextBlock Text="Freitag" Style="{StaticResource HeaderText}"/><TextBlock Text="23. Mai" Style="{StaticResource MutedText}" HorizontalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"><TextBlock Text="Samstag" Style="{StaticResource HeaderText}"/><TextBlock Text="24. Mai" Style="{StaticResource MutedText}" HorizontalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="7" VerticalAlignment="Center"><TextBlock Text="Sonntag" Style="{StaticResource HeaderText}"/><TextBlock Text="25. Mai" Style="{StaticResource MutedText}" HorizontalAlignment="Center"/></StackPanel>

                            <!-- grid separators -->
                            <Border Grid.Row="1" Grid.RowSpan="7" Grid.Column="0" BorderBrush="#EEF2F7" BorderThickness="0,0,1,0"/>
                            <Border Grid.Row="1" Grid.ColumnSpan="8" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1"/>
                            <Border Grid.Row="2" Grid.ColumnSpan="8" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1"/>
                            <Border Grid.Row="3" Grid.ColumnSpan="8" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1"/>
                            <Border Grid.Row="4" Grid.ColumnSpan="8" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1"/>
                            <Border Grid.Row="5" Grid.ColumnSpan="8" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1"/>
                            <Border Grid.Row="6" Grid.ColumnSpan="8" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1"/>

                            <!-- employees -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center"><TextBlock Text="👩" FontSize="25" Margin="0,0,10,0"/><StackPanel><TextBlock Text="Anna Berger" FontWeight="SemiBold" FontSize="11"/><TextBlock Text="Pflegefachkraft" Foreground="#64748B" FontSize="10"/><TextBlock Text="● Verfügbar" Foreground="#16A34A" FontSize="10"/></StackPanel></StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center"><TextBlock Text="👨" FontSize="25" Margin="0,0,10,0"/><StackPanel><TextBlock Text="Lukas Hofmann" FontWeight="SemiBold" FontSize="11"/><TextBlock Text="Pflegefachkraft" Foreground="#64748B" FontSize="10"/><TextBlock Text="● Verfügbar" Foreground="#16A34A" FontSize="10"/></StackPanel></StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center"><TextBlock Text="👩" FontSize="25" Margin="0,0,10,0"/><StackPanel><TextBlock Text="Julia Schneider" FontWeight="SemiBold" FontSize="11"/><TextBlock Text="Altenpflegerin" Foreground="#64748B" FontSize="10"/><TextBlock Text="● Eingeschränkt" Foreground="#F59E0B" FontSize="10"/></StackPanel></StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center"><TextBlock Text="👨" FontSize="25" Margin="0,0,10,0"/><StackPanel><TextBlock Text="Markus Weber" FontWeight="SemiBold" FontSize="11"/><TextBlock Text="Pflegehelfer" Foreground="#64748B" FontSize="10"/><TextBlock Text="● Verfügbar" Foreground="#16A34A" FontSize="10"/></StackPanel></StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center"><TextBlock Text="👩" FontSize="25" Margin="0,0,10,0"/><StackPanel><TextBlock Text="Sarah Müller" FontWeight="SemiBold" FontSize="11"/><TextBlock Text="Pflegefachkraft" Foreground="#64748B" FontSize="10"/><TextBlock Text="● Verfügbar" Foreground="#16A34A" FontSize="10"/></StackPanel></StackPanel>
                            <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center"><TextBlock Text="👨" FontSize="25" Margin="0,0,10,0"/><StackPanel><TextBlock Text="Thomas Richter" FontWeight="SemiBold" FontSize="11"/><TextBlock Text="Pflegehelfer" Foreground="#64748B" FontSize="10"/><TextBlock Text="● Eingeschränkt" Foreground="#F59E0B" FontSize="10"/></StackPanel></StackPanel>
                            <StackPanel Grid.Row="7" Grid.Column="0" Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center"><TextBlock Text="👩" FontSize="25" Margin="0,0,10,0"/><StackPanel><TextBlock Text="Lisa Wagner" FontWeight="SemiBold" FontSize="11"/><TextBlock Text="Pflegefachkraft" Foreground="#64748B" FontSize="10"/><TextBlock Text="● Abwesend" Foreground="#DC2626" FontSize="10"/></StackPanel></StackPanel>

                            <!-- Row 1 -->
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CellShift}" Background="#DCFCE7"><StackPanel><TextBlock Text="06:00 – 14:00" Foreground="#166534" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Frühschicht" Foreground="#166534" FontSize="10" HorizontalAlignment="Center"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CellShift}" Background="#DCFCE7"><StackPanel><TextBlock Text="06:00 – 14:00" Foreground="#166534" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Frühschicht" Foreground="#166534" FontSize="10" HorizontalAlignment="Center"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource CellShift}" Background="#DCFCE7"><StackPanel><TextBlock Text="06:00 – 14:00" Foreground="#166534" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Frühschicht" Foreground="#166534" FontSize="10" HorizontalAlignment="Center"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource CellShift}" Background="#DCFCE7"><StackPanel><TextBlock Text="06:00 – 14:00" Foreground="#166534" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Frühschicht" Foreground="#166534" FontSize="10" HorizontalAlignment="Center"/></StackPanel></Border>
                            <TextBlock Grid.Row="1" Grid.Column="5" Text="-" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            <Border Grid.Row="1" Grid.Column="6" Style="{StaticResource CellShift}" Background="#FFEDD5"><StackPanel><TextBlock Text="14:00 – 22:00" Foreground="#C2410C" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Spätschicht" Foreground="#C2410C" FontSize="10" HorizontalAlignment="Center"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="7" Style="{StaticResource CellShift}" Background="#FFEDD5"><StackPanel><TextBlock Text="14:00 – 22:00" Foreground="#C2410C" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Spätschicht" Foreground="#C2410C" FontSize="10" HorizontalAlignment="Center"/></StackPanel></Border>

                            <!-- Row 2 -->
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CellShift}" Background="#FFEDD5"><StackPanel><TextBlock Text="14:00 – 22:00" Foreground="#C2410C" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Spätschicht" Foreground="#C2410C" FontSize="10" HorizontalAlignment="Center"/></StackPanel></Border>
                            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CellShift}" Background="#FFEDD5"><StackPanel><TextBlock Text="14:00 – 22:00" Foreground="#C2410C" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Spätschicht" Foreground="#C2410C" FontSize="10" HorizontalAlignment="Center"/></StackPanel></Border>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="-" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
