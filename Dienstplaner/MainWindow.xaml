<Window x:Class="Dienstplaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dienstplaner"
        Height="900"
        Width="1440"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Margin" Value="0,6,0,3"/>
        </Style>

        <DataTemplate x:Key="SchichtKartenTemplate">
            <Border MinWidth="130"
                    Margin="4"
                    Padding="10"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Zeitfenster}"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                        <Border Grid.Column="1" Background="#FEF3C7" CornerRadius="9" Padding="6,2">
                            <TextBlock Text="{Binding Warnstatus}" FontSize="10" Foreground="#92400E"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding Name}"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding RolleAnzeige, StringFormat={}Rolle: {0}}"
                               FontSize="11"
                               Foreground="#374151"/>
                    <TextBlock Text="{Binding BesetzungText, StringFormat={}Besetzung: {0}}"
                               FontSize="11"
                               Foreground="#374151"/>
                    <TextBlock Text="{Binding Filiale, StringFormat={}Filiale: {0}}"
                               FontSize="10"
                               Foreground="#6B7280"/>
                    <ItemsControl ItemsSource="{Binding MitarbeiterNamen}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#DBEAFE" CornerRadius="5" Padding="5,2" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding}" FontSize="10" Foreground="#1E3A8A"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1B3A5C">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Dienstplaner"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Planungsorientierte Wochenansicht für Filialen, Rollen und Teams"
                               Foreground="#BFDBFE"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Schicht kopieren"
                            Style="{StaticResource PrimaryButton}"
                            Width="120"
                            Margin="0,0,8,0"
                            Command="{Binding SchichtKopierenCommand}"/>
                    <Button Content="Schicht verschieben"
                            Style="{StaticResource PrimaryButton}"
                            Width="135"
                            Background="#0F766E"
                            Margin="0"
                            Command="{Binding SchichtVerschiebenCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: FILTERS AND CREATION -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Planfilter"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Filiale" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding FilterFiliale, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Abteilung" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding FilterAbteilung, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Woche" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding FilterWoche, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Rolle" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding FilterRolle, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Mitarbeiter" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Height="30"
                                      ItemsSource="{Binding MitarbeiterListe}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding FilterMitarbeiter}"/>

                            <UniformGrid Columns="2" Margin="0,10,0,0">
                                <Button Content="Anwenden"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,4,0"
                                        Command="{Binding FilterAnwendenCommand}"/>
                                <Button Content="Zurücksetzen"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#6B7280"
                                        Margin="4,0,0,0"
                                        Command="{Binding FilterZuruecksetzenCommand}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Mitarbeiter hinzufügen"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding NeuerMitarbeiterName}"/>

                            <TextBlock Text="Abteilung" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding NeueMitarbeiterAbteilung}"/>

                            <TextBlock Text="Qualifikation" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding NeuerMitarbeiterQualifikation}"/>

                            <Button Content="Mitarbeiter hinzufügen"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#2563EB"
                                    Command="{Binding MitarbeiterHinzufuegenCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Schicht hinzufügen"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Schichtname" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding NeueSchichtName}"/>

                            <TextBlock Text="Abteilung / Rolle" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding NeueSchichtAbteilung}"/>

                            <TextBlock Text="Wochentag" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding NeueSchichtWochentag}"/>

                            <TextBlock Text="Benötigte Mitarbeiter" Style="{StaticResource FieldLabel}"/>
                            <TextBox Height="30" Text="{Binding NeueSchichtKapazitaet}"/>

                            <Button Content="Schicht erstellen"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#059669"
                                    Command="{Binding SchichtHinzufuegenCommand}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- CENTER: WEEK CALENDAR -->
            <Grid Grid.Column="1" Margin="12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Wochenkalender"
                                       FontWeight="Bold"
                                       FontSize="18"/>
                            <TextBlock Text="Tage als Spalten, Bereiche und Rollen als Zeilen. Karten können ausgewählt, kopiert oder verschoben werden."
                                       Foreground="#6B7280"
                                       FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#DCFCE7" CornerRadius="12" Padding="10,4" Margin="0,0,6,0">
                                <TextBlock Text="OK" Foreground="#166534" FontWeight="SemiBold" FontSize="11"/>
                            </Border>
                            <Border Background="#FEF3C7" CornerRadius="12" Padding="10,4" Margin="0,0,6,0">
                                <TextBlock Text="Warnung" Foreground="#92400E" FontWeight="SemiBold" FontSize="11"/>
                            </Border>
                            <Border Background="#FEE2E2" CornerRadius="12" Padding="10,4">
                                <TextBlock Text="Konflikt" Foreground="#991B1B" FontWeight="SemiBold" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid MinWidth="900">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1">
                                <TextBlock Text="Bereich / Rolle" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0"/>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1"><TextBlock Text="Montag" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            <Border Grid.Row="0" Grid.Column="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1"><TextBlock Text="Dienstag" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            <Border Grid.Row="0" Grid.Column="3" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1"><TextBlock Text="Mittwoch" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            <Border Grid.Row="0" Grid.Column="4" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1"><TextBlock Text="Donnerstag" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            <Border Grid.Row="0" Grid.Column="5" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1"><TextBlock Text="Freitag" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            <Border Grid.Row="0" Grid.Column="6" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1"><TextBlock Text="Samstag" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            <Border Grid.Row="0" Grid.Column="7" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"><TextBlock Text="Sonntag" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>

                            <ItemsControl Grid.Row="1" Grid.ColumnSpan="8" ItemsSource="{Binding WochenplanZeilen}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MinHeight="170">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1" Padding="10">
                                                <TextBlock Text="{Binding Rolle}"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="1" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1" Padding="4">
                                                <ItemsControl ItemsSource="{Binding Montag}" ItemTemplate="{StaticResource SchichtKartenTemplate}"/>
                                            </Border>
                                            <Border Grid.Column="2" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1" Padding="4">
                                                <ItemsControl ItemsSource="{Binding Dienstag}" ItemTemplate="{StaticResource SchichtKartenTemplate}"/>
                                            </Border>
                                            <Border Grid.Column="3" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1" Padding="4">
                                                <ItemsControl ItemsSource="{Binding Mittwoch}" ItemTemplate="{StaticResource SchichtKartenTemplate}"/>
                                            </Border>
                                            <Border Grid.Column="4" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1" Padding="4">
                                                <ItemsControl ItemsSource="{Binding Donnerstag}" ItemTemplate="{StaticResource SchichtKartenTemplate}"/>
                                            </Border>
                                            <Border Grid.Column="5" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1" Padding="4">
                                                <ItemsControl ItemsSource="{Binding Freitag}" ItemTemplate="{StaticResource SchichtKartenTemplate}"/>
                                            </Border>
                                            <Border Grid.Column="6" BorderBrush="#E5E7EB" BorderThickness="0,0,1,1" Padding="4">
                                                <ItemsControl ItemsSource="{Binding Samstag}" ItemTemplate="{StaticResource SchichtKartenTemplate}"/>
                                            </Border>
                                            <Border Grid.Column="7" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="4">
                                                <ItemsControl ItemsSource="{Binding Sonntag}" ItemTemplate="{StaticResource SchichtKartenTemplate}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- RIGHT: ASSIGNMENTS, METRICS, EMPLOYEE VIEW -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Zuweisung"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Mitarbeiter" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Height="30"
                                      ItemsSource="{Binding MitarbeiterListe}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding AusgewaehlterMitarbeiter}"/>

                            <TextBlock Text="Schicht" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Height="30"
                                      ItemsSource="{Binding SchichtListe}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding AusgewaehlteSchicht}"/>

                            <Button Content="Mitarbeiter zuweisen"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#EA580C"
                                    Command="{Binding ZuweisenCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Kopieren / Verschieben"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Quelle" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Height="30"
                                      ItemsSource="{Binding SchichtListe}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding AusgewaehlteSchicht}"/>
                            <TextBlock Text="Ziel" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Height="30"
                                      ItemsSource="{Binding SchichtListe}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding AusgewaehlteZielSchicht}"/>
                            <UniformGrid Columns="2" Margin="0,10,0,0">
                                <Button Content="Schicht"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,4,0"
                                        Command="{Binding SchichtKopierenCommand}"/>
                                <Button Content="Schicht move"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#0F766E"
                                        Margin="4,0,0,0"
                                        Command="{Binding SchichtVerschiebenCommand}"/>
                                <Button Content="Zuw. kopieren"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#7C3AED"
                                        Margin="0,8,4,0"
                                        Command="{Binding ZuweisungenKopierenCommand}"/>
                                <Button Content="Zuw. move"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#9333EA"
                                        Margin="4,8,0,0"
                                        Command="{Binding ZuweisungenVerschiebenCommand}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Besetzungskennzahlen"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>
                            <UniformGrid Columns="2">
                                <Border Background="#EFF6FF" CornerRadius="8" Padding="10" Margin="0,0,5,8">
                                    <StackPanel><TextBlock Text="Soll" FontSize="11"/><TextBlock Text="{Binding BesetzungSoll}" FontSize="22" FontWeight="Bold"/></StackPanel>
                                </Border>
                                <Border Background="#ECFDF5" CornerRadius="8" Padding="10" Margin="5,0,0,8">
                                    <StackPanel><TextBlock Text="Ist" FontSize="11"/><TextBlock Text="{Binding BesetzungIst}" FontSize="22" FontWeight="Bold"/></StackPanel>
                                </Border>
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="10" Margin="0,0,5,0">
                                    <StackPanel><TextBlock Text="Differenz" FontSize="11"/><TextBlock Text="{Binding BesetzungsDifferenz}" FontSize="22" FontWeight="Bold"/></StackPanel>
                                </Border>
                                <Border Background="#FEE2E2" CornerRadius="8" Padding="10" Margin="5,0,0,0">
                                    <StackPanel><TextBlock Text="Konflikte" FontSize="11"/><TextBlock Text="{Binding KonfliktAnzahl}" FontSize="22" FontWeight="Bold"/></StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Mitarbeiteransicht (geplant)"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Eigene Schichten" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Text="Persönlicher Wochenplan mit bestätigten und offenen Einsätzen." TextWrapping="Wrap" Foreground="#6B7280" FontSize="12"/>
                            <TextBlock Text="Tauschanfragen" FontWeight="SemiBold" Margin="0,10,0,2"/>
                            <TextBlock Text="Anfragen stellen, freigeben und Status verfolgen." TextWrapping="Wrap" Foreground="#6B7280" FontSize="12"/>
                            <TextBlock Text="Verfügbarkeiten" FontWeight="SemiBold" Margin="0,10,0,2"/>
                            <TextBlock Text="Wunschzeiten, Sperrzeiten und Abwesenheiten für die Planung pflegen." TextWrapping="Wrap" Foreground="#6B7280" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Mitarbeiter Übersicht"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding MitarbeiterListe}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Filiale, StringFormat={}Filiale: {0}}" FontSize="11" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Abteilung, StringFormat={}Abteilung: {0}}" FontSize="11" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Qualifikation, StringFormat={}Qualifikation: {0}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Schichten.Count, StringFormat={}Schichten: {0}}" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#1B3A5C">
            <TextBlock Text="{Binding StatusNachricht}"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
        </Border>
    </Grid>
</Window>
