<Window x:Class="Dienstplaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dienstplaner"
        Height="900"
        Width="1440"
        Background="#F3F4F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1B3A5C">
            <Grid>
                <TextBlock Text="Dienstplaner · Integrationen, Exporte und Auswertungen"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="20,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Mitarbeiter hinzufügen" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                            <TextBlock Text="Name" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeuerMitarbeiterName}" Margin="0,0,0,8"/>
                            <TextBlock Text="Abteilung" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueMitarbeiterAbteilung}" Margin="0,0,0,8"/>
                            <TextBlock Text="Qualifikation" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeuerMitarbeiterQualifikation}" Margin="0,0,0,8"/>
                            <TextBlock Text="Sollstunden/Woche" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueMitarbeiterSollstunden}" Margin="0,0,0,8"/>
                            <TextBlock Text="Stundenlohn" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeuerMitarbeiterStundenlohn}" Margin="0,0,0,12"/>
                            <Button Content="Mitarbeiter hinzufügen" Height="36" Background="#2563EB" Foreground="White" BorderThickness="0" Command="{Binding MitarbeiterHinzufuegenCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Schicht hinzufügen" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                            <TextBlock Text="Schichtname" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtName}" Margin="0,0,0,8"/>
                            <TextBlock Text="Abteilung" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtAbteilung}" Margin="0,0,0,8"/>
                            <TextBlock Text="Wochentag" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtWochentag}" Margin="0,0,0,8"/>
                            <TextBlock Text="Benötigte Mitarbeiter" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtKapazitaet}" Margin="0,0,0,8"/>
                            <TextBlock Text="Pausenstunden" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtPausenstunden}" Margin="0,0,0,8"/>
                            <TextBlock Text="Zuschlagsstunden" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtZuschlagsstunden}" Margin="0,0,0,12"/>
                            <Button Content="Schicht erstellen" Height="36" Background="#059669" Foreground="White" BorderThickness="0" Command="{Binding SchichtHinzufuegenCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="6" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Forecast importieren" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock Text="CSV: FilialeId;Filiale;Datum;Umsatz;Kunden" FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBox Height="32" Text="{Binding ForecastImportPfad}" Margin="0,0,0,8"/>
                            <Button Content="Umsatz/Kundenfrequenz importieren" Height="36" Background="#7C3AED" Foreground="White" BorderThickness="0" Command="{Binding ForecastImportCommand}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Column="1" Margin="10,0">
                <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Zuweisung" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Height="32" ItemsSource="{Binding MitarbeiterListe}" DisplayMemberPath="Name" SelectedItem="{Binding AusgewaehlterMitarbeiter}" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" Height="32" ItemsSource="{Binding SchichtListe}" DisplayMemberPath="Name" SelectedItem="{Binding AusgewaehlteSchicht}" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="Mitarbeiter zuweisen" Height="32" Background="#EA580C" Foreground="White" BorderThickness="0" Command="{Binding ZuweisenCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Geschützte Exporte" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>
                        <TextBlock Text="Mandant und Rolle werden vor jedem CSV-, Excel- oder PDF-Export geprüft." FontSize="11" Opacity="0.7" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="CSV" Width="90" Height="32" Margin="0,0,8,0" Command="{Binding CsvExportCommand}"/>
                            <Button Content="Excel" Width="90" Height="32" Margin="0,0,8,0" Command="{Binding ExcelExportCommand}"/>
                            <Button Content="PDF" Width="90" Height="32" Command="{Binding PdfExportCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Geplante Schichten" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="560">
                            <ItemsControl ItemsSource="{Binding SchichtListe}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                <TextBlock Text="{Binding FilialeName, StringFormat=Filiale: {0}}" FontSize="11" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Abteilung, StringFormat=Abteilung: {0}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Wochentag, StringFormat=Tag: {0}}" FontSize="11"/>
                                                <TextBlock Text="{Binding NettoDauerInStunden, StringFormat=Netto-Iststunden: {0} h}" FontSize="11"/>
                                                <TextBlock Text="{Binding Pausenstunden, StringFormat=Pause: {0} h}" FontSize="11"/>
                                                <TextBlock Text="{Binding Zuschlagsstunden, StringFormat=Zuschlag: {0} h}" FontSize="11"/>
                                                <TextBlock Text="{Binding BenoetigteMitarbeiter, StringFormat=Benötigt: {0} Mitarbeiter}" FontSize="11"/>
                                                <TextBlock Text="{Binding MitarbeiterNamen.Count, StringFormat=Zugewiesen: {0}}" FontSize="11" Margin="0,0,0,5"/>
                                                <ItemsControl ItemsSource="{Binding MitarbeiterNamen}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#EEF2FF" CornerRadius="4" Padding="4" Margin="0,2,0,2">
                                                                <TextBlock Text="{Binding}" FontSize="11"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Reports" FontWeight="Bold" FontSize="15" Width="250"/>
                            <Button Content="Aktualisieren" Command="{Binding ReportsAktualisierenCommand}"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding ReportListe}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="6">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Wert}" FontSize="18" Foreground="#1B3A5C"/>
                                            <TextBlock Text="{Binding Hinweis}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Lohn &amp; Zeiterfassung" FontWeight="Bold" FontSize="15" Width="250"/>
                            <Button Content="Aktualisieren" Command="{Binding IntegrationenAktualisierenCommand}"/>
                        </StackPanel>
                        <TextBlock Text="Lohnabrechnung" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding LohnabrechnungListe}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="11" Text="{Binding MitarbeiterName, StringFormat={}{0}: Soll/Ist, Überstunden und Kosten bereitgestellt}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Zeiterfassung" FontWeight="SemiBold" Margin="0,8,0,4"/>
                        <ItemsControl ItemsSource="{Binding ZeiterfassungListe}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="11" Text="{Binding SchichtName, StringFormat={}{0}: Start/Ende/Pause/Kostenstelle}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Forecasts je Filiale" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>
                        <ScrollViewer Height="120">
                            <ItemsControl ItemsSource="{Binding ForecastListe}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="11" Text="{Binding FilialeName, StringFormat={}{0}: Umsatz/Kunden importiert}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Systemstatus" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding StatusNachricht}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#1B3A5C">
            <TextBlock Text="{Binding StatusNachricht}" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
