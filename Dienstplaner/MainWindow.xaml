<Window x:Class="Dienstplaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dienstplaner"
        Height="900"
        Width="1440"
        Background="#F3F4F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1B3A5C">
            <TextBlock Text="Dienstplaner - Verfügbarkeit &amp; Freigaben"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="20,0"/>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Mitarbeiter hinzufügen" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                            <TextBlock Text="Name" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeuerMitarbeiterName}" Margin="0,0,0,8"/>
                            <TextBlock Text="Abteilung" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueMitarbeiterAbteilung}" Margin="0,0,0,8"/>
                            <TextBlock Text="Qualifikation" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeuerMitarbeiterQualifikation}" Margin="0,0,0,8"/>
                            <Button Content="Mitarbeiter hinzufügen" Height="36" Background="#2563EB" Foreground="White" BorderThickness="0" Command="{Binding MitarbeiterHinzufuegenCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Schicht hinzufügen" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                            <TextBlock Text="Schichtname" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtName}" Margin="0,0,0,8"/>
                            <TextBlock Text="Abteilung" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtAbteilung}" Margin="0,0,0,8"/>
                            <TextBlock Text="Wochentag" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtWochentag}" Margin="0,0,0,8"/>
                            <TextBlock Text="Benötigte Mitarbeiter" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="32" Text="{Binding NeueSchichtKapazitaet}" Margin="0,0,0,12"/>
                            <Button Content="Schicht erstellen" Height="36" Background="#059669" Foreground="White" BorderThickness="0" Command="{Binding SchichtHinzufuegenCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="6" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Mitarbeiter Übersicht" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                            <ScrollViewer Height="260">
                                <ItemsControl ItemsSource="{Binding MitarbeiterListe}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Abteilung, StringFormat=Abteilung: {0}}" FontSize="11" Opacity="0.7"/>
                                                    <TextBlock Text="{Binding Qualifikation, StringFormat=Qualifikation: {0}}" FontSize="11"/>
                                                    <TextBlock Text="{Binding Schichten.Count, StringFormat=Schichten: {0}}" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" Margin="10,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Zuweisung mit Verfügbarkeitsprüfung" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                            <TextBlock Text="Mitarbeiter" FontSize="11" Margin="0,0,0,3"/>
                            <ComboBox Height="32" ItemsSource="{Binding MitarbeiterListe}" DisplayMemberPath="Name" SelectedItem="{Binding AusgewaehlterMitarbeiter}" Margin="0,0,0,8"/>
                            <TextBlock Text="Schicht" FontSize="11" Margin="0,0,0,3"/>
                            <ComboBox Height="32" ItemsSource="{Binding SchichtListe}" DisplayMemberPath="Name" SelectedItem="{Binding AusgewaehlteSchicht}" Margin="0,0,0,12"/>
                            <Button Content="Mitarbeiter zuweisen" Height="36" Background="#EA580C" Foreground="White" BorderThickness="0" Command="{Binding ZuweisenCommand}"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="14" Margin="0,0,5,10">
                            <StackPanel>
                                <TextBlock Text="Mitarbeiteranträge" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                                <TextBlock Text="Verfügbarkeit" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Height="30" Text="{Binding VerfuegbarkeitWochentag}" Margin="0,0,0,6" ToolTip="Wochentag"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBox Width="90" Height="30" Text="{Binding VerfuegbarkeitVon}" ToolTip="Von"/>
                                    <TextBox Width="90" Height="30" Text="{Binding VerfuegbarkeitBis}" Margin="8,0,0,0" ToolTip="Bis"/>
                                </StackPanel>
                                <TextBox Height="52" Text="{Binding AntragKommentar}" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8" ToolTip="Kommentar"/>
                                <Button Content="Verfügbarkeit einreichen" Height="32" Background="#2563EB" Foreground="White" BorderThickness="0" Command="{Binding VerfuegbarkeitEinreichenCommand}"/>

                                <TextBlock Text="Abwesenheit" FontWeight="SemiBold" Margin="0,14,0,6"/>
                                <TextBox Height="30" Text="{Binding AbwesenheitVon}" Margin="0,0,0,6" ToolTip="Von Datum/Uhrzeit"/>
                                <TextBox Height="30" Text="{Binding AbwesenheitBis}" Margin="0,0,0,6" ToolTip="Bis Datum/Uhrzeit"/>
                                <TextBox Height="30" Text="{Binding AbwesenheitGrund}" Margin="0,0,0,8" ToolTip="Grund"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Urlaub" Width="95" Height="32" Background="#059669" Foreground="White" BorderThickness="0" Command="{Binding UrlaubsantragEinreichenCommand}"/>
                                    <Button Content="Krank" Width="95" Height="32" Margin="8,0,0,0" Background="#DC2626" Foreground="White" BorderThickness="0" Command="{Binding KrankmeldungEinreichenCommand}"/>
                                </StackPanel>
                                <Button Content="Schichttausch einreichen" Height="32" Margin="0,8,0,0" Background="#7C3AED" Foreground="White" BorderThickness="0" Command="{Binding TauschAntragEinreichenCommand}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="14" Margin="5,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Geplante Schichten" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                                <ScrollViewer Height="420">
                                    <ItemsControl ItemsSource="{Binding SchichtListe}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                        <TextBlock Text="{Binding Abteilung, StringFormat=Abteilung: {0}}" FontSize="11" Opacity="0.7"/>
                                                        <TextBlock Text="{Binding Wochentag, StringFormat=Tag: {0}}" FontSize="11"/>
                                                        <TextBlock Text="{Binding Start, StringFormat=Start: {0:g}}" FontSize="11"/>
                                                        <TextBlock Text="{Binding Ende, StringFormat=Ende: {0:g}}" FontSize="11"/>
                                                        <TextBlock Text="{Binding BenoetigteMitarbeiter, StringFormat=Benötigt: {0} Mitarbeiter}" FontSize="11"/>
                                                        <TextBlock Text="{Binding MitarbeiterNamen.Count, StringFormat=Zugewiesen: {0}}" FontSize="11" Margin="0,0,0,5"/>
                                                        <ItemsControl ItemsSource="{Binding MitarbeiterNamen}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#EEF2FF" CornerRadius="4" Padding="4" Margin="0,2,0,2">
                                                                        <TextBlock Text="{Binding}" FontSize="11"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Manager-Freigaben" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                            <TextBlock Text="Entscheider" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Height="30" Text="{Binding EntscheidungsBenutzer}" Margin="0,0,0,6"/>
                            <TextBlock Text="Rolle" FontSize="11" Margin="0,0,0,3"/>
                            <ComboBox Height="30" ItemsSource="{Binding Rollen}" SelectedItem="{Binding EntscheidungsRolle}" Margin="0,0,0,6"/>
                            <TextBox Height="52" Text="{Binding EntscheidungsKommentar}" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" ToolTip="Entscheidungskommentar"/>

                            <TextBlock Text="Verfügbarkeiten" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox Height="110" ItemsSource="{Binding Verfuegbarkeiten}" SelectedItem="{Binding AusgewaehlteVerfuegbarkeit}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding MitarbeiterName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Wochentag, StringFormat=Tag: {0}}" FontSize="11"/>
                                            <TextBlock Text="{Binding Zeitraum, StringFormat=Zeit: {0}}" FontSize="11"/>
                                            <TextBlock Text="{Binding Status, StringFormat=Status: {0}}" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,10">
                                <Button Content="Genehmigen" Width="100" Height="30" Background="#059669" Foreground="White" BorderThickness="0" Command="{Binding VerfuegbarkeitGenehmigenCommand}"/>
                                <Button Content="Ablehnen" Width="90" Height="30" Margin="8,0,0,0" Background="#DC2626" Foreground="White" BorderThickness="0" Command="{Binding VerfuegbarkeitAblehnenCommand}"/>
                            </StackPanel>

                            <TextBlock Text="Abwesenheiten" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox Height="110" ItemsSource="{Binding Abwesenheiten}" SelectedItem="{Binding AusgewaehlteAbwesenheit}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding MitarbeiterName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Grund, StringFormat=Grund: {0}}" FontSize="11"/>
                                            <TextBlock Text="{Binding Status, StringFormat=Status: {0}}" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,10">
                                <Button Content="Genehmigen" Width="100" Height="30" Background="#059669" Foreground="White" BorderThickness="0" Command="{Binding AbwesenheitGenehmigenCommand}"/>
                                <Button Content="Ablehnen" Width="90" Height="30" Margin="8,0,0,0" Background="#DC2626" Foreground="White" BorderThickness="0" Command="{Binding AbwesenheitAblehnenCommand}"/>
                            </StackPanel>

                            <TextBlock Text="Schichttausch" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox Height="90" ItemsSource="{Binding TauschAntraege}" SelectedItem="{Binding AusgewaehlterTauschAntrag}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding SchichtName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding VonMitarbeiterName, StringFormat=Von: {0}}" FontSize="11"/>
                                            <TextBlock Text="{Binding Status, StringFormat=Status: {0}}" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Genehmigen" Width="100" Height="30" Background="#059669" Foreground="White" BorderThickness="0" Command="{Binding TauschGenehmigenCommand}"/>
                                <Button Content="Ablehnen" Width="90" Height="30" Margin="8,0,0,0" Background="#DC2626" Foreground="White" BorderThickness="0" Command="{Binding TauschAblehnenCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Entscheidungsprotokoll" FontWeight="Bold" FontSize="15" Margin="0,0,0,12"/>
                            <ScrollViewer Height="160">
                                <ItemsControl ItemsSource="{Binding EntscheidungsLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding AntragTyp}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding NeuerStatus, StringFormat=Status: {0}}" FontSize="11"/>
                                                    <TextBlock Text="{Binding Benutzer, StringFormat=Benutzer: {0}}" FontSize="11"/>
                                                    <TextBlock Text="{Binding Zeitpunkt, StringFormat=Zeitpunkt: {0:g}}" FontSize="11"/>
                                                    <TextBlock Text="{Binding Kommentar, StringFormat=Kommentar: {0}}" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="6" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Systemstatus" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding StatusNachricht}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="#1B3A5C">
            <TextBlock Text="{Binding StatusNachricht}" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
