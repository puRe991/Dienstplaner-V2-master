<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <!-- Configure these values to match the OpenID Connect provider that issues JWT bearer tokens. -->
        <add key="Auth:Authority" value="https://identity.example.com/" />
        <add key="Auth:Audience" value="dienstplaner-api" />
        <add key="Auth:RequiredIssuer" value="https://identity.example.com/" />
    </appSettings>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
</configuration>
